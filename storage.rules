rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /users/{uid}/{allPaths=**} {
      // Only the account owner can read/write their files
      allow read: if request.auth != null && request.auth.uid == uid;
      // Enforce per-file size limits at the storage layer too
      allow write: if request.auth != null
                   && request.auth.uid == uid
                   && request.resource.size < 200 * 1024 * 1024; // 200 MB hard cap
    }
  }
}
