rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // True when the signed-in user's email appears in the owner's sharedWithEmails list.
    function isSharedWith(uid) {
      return request.auth != null
          && request.auth.token.email != null
          && request.auth.token.email in
               get(/databases/$(database)/documents/users/$(uid)).data.sharedWithEmails;
    }

    match /users/{uid} {
      // Any signed-in user can read the top-level doc (email lookup + feed count query).
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;

      // Profiles: owner full access; invited users read-only.
      match /profiles/{profileId} {
        allow read: if request.auth != null
                    && (request.auth.uid == uid || isSharedWith(uid));
        allow write: if request.auth != null && request.auth.uid == uid;

        // Milestones: owner full access; invited users read-only.
        match /milestones/{milestoneId} {
          allow read: if request.auth != null
                      && (request.auth.uid == uid || isSharedWith(uid));
          allow write: if request.auth != null && request.auth.uid == uid;
        }

        // Everything else under a profile (reminders, documents, links…): owner only.
        match /{rest=**} {
          allow read, write: if request.auth != null && request.auth.uid == uid;
        }
      }

      // Notifications: owner can read/delete; a sender can create one only if
      // the recipient's email is in the sender's own sharedWithEmails list,
      // and only with the exact fields the app writes.
      match /notifications/{notifId} {
        allow read, delete: if request.auth != null && request.auth.uid == uid;
        allow create: if request.auth != null
                      && request.resource.data.keys().hasOnly(
                           ['senderName', 'milestoneTitle', 'timestamp', 'read'])
                      && request.resource.data.read == false
                      && get(/databases/$(database)/documents/users/$(uid)).data.email in
                           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.sharedWithEmails;
      }

      // Everything else under the user doc: owner only.
      match /{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // Community stories: readable by any signed-in user. Authors own their
    // posts; other users may only toggle likes (likedByUids is the sole
    // field they can touch, and authorId can never change after creation).
    match /blogs/{blogId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.authorId == request.auth.uid;
      allow update: if request.auth != null
                    && request.resource.data.authorId == resource.data.authorId
                    && (request.auth.uid == resource.data.authorId
                        || request.resource.data.diff(resource.data)
                             .affectedKeys().hasOnly(['likedByUids']));
      allow delete: if request.auth != null
                    && request.auth.uid == resource.data.authorId;
    }

    // Community Q&A forum. Authors own their questions; other users may only
    // bump the denormalized answerCount when posting/removing answers.
    match /forum/{questionId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.authorId == request.auth.uid;
      allow update: if request.auth != null
                    && request.resource.data.authorId == resource.data.authorId
                    && (request.auth.uid == resource.data.authorId
                        || request.resource.data.diff(resource.data)
                             .affectedKeys().hasOnly(['answerCount']));
      allow delete: if request.auth != null
                    && request.auth.uid == resource.data.authorId;

      // Answers: author-owned; the question's author may also delete answers
      // (needed when deleting a whole question).
      match /answers/{answerId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null
                      && request.resource.data.authorId == request.auth.uid;
        allow update: if request.auth != null
                      && request.auth.uid == resource.data.authorId
                      && request.resource.data.authorId == resource.data.authorId;
        allow delete: if request.auth != null
                      && (request.auth.uid == resource.data.authorId
                          || request.auth.uid ==
                               get(/databases/$(database)/documents/forum/$(questionId)).data.authorId);
      }
    }
  }
}
