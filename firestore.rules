rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── User profiles ──────────────────────────────────────────────────────────
    // Own data: full access. Others: read-only (needed for invite lookup).
    match /users/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;

      match /{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // ── Connections ────────────────────────────────────────────────────────────
    // Any authenticated user can create a connection.
    // Members of the connection (or users whose email matches toEmail) can read.
    match /connections/{connectionId} {
      allow create: if request.auth != null
                    && request.resource.data.fromUid == request.auth.uid;
      // members-based read supports arrayContains queries (myConnectionsStream).
      // toEmail check lets claimPendingInvites() read docs sent to this email
      // before the recipient's uid was known.
      allow read: if request.auth != null
                  && (request.auth.uid in resource.data.members
                      || request.auth.uid == resource.data.fromUid
                      || request.auth.uid == resource.data.toUid
                      || resource.data.toEmail == request.auth.token.email);
      allow update: if request.auth != null
                    && (request.auth.uid == resource.data.fromUid
                        || request.auth.uid == resource.data.toUid
                        || resource.data.toEmail == request.auth.token.email);
      allow delete: if request.auth != null
                    && (request.auth.uid == resource.data.fromUid
                        || request.auth.uid == resource.data.toUid);
    }

    // ── Shared memories ────────────────────────────────────────────────────────
    // Only users in visibleTo can read. Only fromUid can write the root doc.
    match /shared_memories/{memoryId} {
      allow create: if request.auth != null
                    && request.resource.data.fromUid == request.auth.uid;
      allow read: if request.auth != null
                  && request.auth.uid in resource.data.visibleTo;
      // Likes update likedByUids — allow any visible user to toggle
      allow update: if request.auth != null
                    && request.auth.uid in resource.data.visibleTo;
      allow delete: if request.auth != null
                    && request.auth.uid == resource.data.fromUid;

      // Comments: any visible user can read/create
      match /comments/{commentId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null;
        allow delete: if request.auth != null
                      && request.auth.uid == resource.data.fromUid;
      }
    }

    // ── Notifications ──────────────────────────────────────────────────────────
    // Only the owner can read their own notifications.
    // Any authenticated user can create (to send a notification to another user).
    match /notifications/{uid}/items/{notifId} {
      allow read, update, delete: if request.auth != null
                                   && request.auth.uid == uid;
      allow create: if request.auth != null;
    }
  }
}
